{
  "name": "shadowboxmaker/woo-barcode-pro",
  "description": "WooCommerce barcode generation, label design, print queue and mobile Quick Add",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0",
    "picqer/php-barcode-generator": "^2.4",
    "mpdf/mpdf": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "WCBarcodePro\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WCBarcodePro\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
